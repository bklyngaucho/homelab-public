# ============================================================
# Homelab Container Stack — Environment Variables
# Copy this file to .env and fill in all values before
# starting containers. Never commit .env to version control.
# ============================================================

# --- Timezone ---
TZ=America/New_York

# --- User/Group IDs ---
# Files on NAS02 NFS shares are owned by 1000:1000
PUID=1000
PGID=1000

# --- NAS02 NFS Mounts (via NAS01 HybridMount UUIDs) ---
# These paths are the NAS01's local mount points for TrueNAS NFS shares.
# UUIDs are assigned by HybridMount when you add a network drive — they're
# stable as long as you don't remove/re-add the entry in HybridMount.
#
# Active 10GbE mounts (10.10.10.31, confirmed working 2026-06-19):
#   media_ds   → 07e08eb2f-9ba6-4c7d-bd45-a6e905f5d115
#   downloads  → 0ea3a0300-66e0-4c00-bc6b-21f7da3cf562
#   backups    → 0c4d1a3ac-b8b7-454d-bfbc-5c7efdc056bc
#
# To find UUIDs on a fresh NAS01: ls /share/external/.nd/1000/ — match by
# checking which directories are non-empty after HybridMount connects.
MEDIA_DS=/share/external/.nd/1000/07e08eb2f-9ba6-4c7d-bd45-a6e905f5d115
DOWNLOADS_DS=/share/external/.nd/1000/0ea3a0300-66e0-4c00-bc6b-21f7da3cf562
BACKUPS=/share/external/.nd/1000/0c4d1a3ac-b8b7-454d-bfbc-5c7efdc056bc

# --- NAS01 Local ---
APPDATA_PATH=/share/appdata

# --- PIA VPN (TransmissionVPN) ---
PIA_USER=YOUR_PIA_USERNAME
PIA_PASS=YOUR_PIA_PASSWORD
OPENVPN_CONFIG=ca_montreal

# --- Duplicati ---
DUPLICATI_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY
DUPLICATI_WEB_PASSWORD=YOUR_WEB_PASSWORD

# --- Cloudflare ---
# API token for NPM DNS challenge (Let's Encrypt cert issuance)
# Generate at: dash.cloudflare.com → My Profile → API Tokens → Edit zone DNS
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN

# --- Recyclarr API Keys ---
# Find these in each app under Settings → General → API Key
SONARR_API_KEY=YOUR_SONARR_API_KEY
RADARR_API_KEY=YOUR_RADARR_API_KEY
RADARR4K_API_KEY=YOUR_RADARR4K_API_KEY

# --- Tdarr ---
# Local NAS01 path for in-progress transcode scratch space (use fast local storage, not NFS)
# Create this directory first: mkdir -p /share/CACHEDEV5_DATA/tdarr-temp
# CACHEDEV5 = NVMe pool (fastest local storage — ideal for in-progress encodes)
TDARR_TRANSCODE_CACHE=/share/CACHEDEV5_DATA/tdarr-temp

# --- Technitium DNS ---
# Admin password for the Technitium web UI (set on first start; change via UI or restart container to reset)
TECHNITIUM_ADMIN_PASSWORD=YOUR_TECHNITIUM_ADMIN_PASSWORD

# --- SABnzbd ---
# API key found in SABnzbd → Settings → General → API Key
# Used by Sonarr/Radarr/Radarr4K download client config and hl.py
SABNZBD_API_KEY=YOUR_SABNZBD_API_KEY

# --- Tailscale ---
# Reusable auth key from tailscale.com → Settings → Keys
# Generate with Reusable=true, Ephemeral=false
TAILSCALE_AUTHKEY=YOUR_TAILSCALE_AUTHKEY

# --- Watchtower notifications (Gmail) ---
# Uses shoutrrr SMTP format. Requires a Gmail App Password (not your account password).
# Generate one at: myaccount.google.com → Security → 2-Step Verification → App Passwords
# Note: @ in the username must be encoded as %40
# Format: smtp://your.email%40gmail.com:APP_PASSWORD@smtp.gmail.com:587/?from=your.email@gmail.com&to=your.email@gmail.com
WATCHTOWER_NOTIFICATION_URL=smtp://YOUR_EMAIL%40gmail.com:YOUR_APP_PASSWORD@smtp.gmail.com:587/?from=YOUR_EMAIL@gmail.com&to=YOUR_EMAIL@gmail.com
